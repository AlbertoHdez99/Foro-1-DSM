package com.example.gestionnotasapp

import android.os.Bundle
import androidx.activity.ComponentActivity
import androidx.activity.compose.setContent
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.text.KeyboardOptions
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.text.input.KeyboardType
import androidx.compose.ui.text.input.PasswordVisualTransformation
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import androidx.navigation.NavHostController
import androidx.navigation.compose.NavHost
import androidx.navigation.compose.composable
import androidx.navigation.compose.rememberNavController

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            val navController = rememberNavController()
            // Sistema de Navegación
            NavHost(navController = navController, startDestination = "login") {
                composable("login") { LoginScreen(navController) }
                composable("welcome/{email}") { backStackEntry ->
                    val email = backStackEntry.arguments?.getString("email") ?: ""
                    WelcomeScreen(navController, email)
                }
                composable("input") { GradesScreen(navController) }
                composable("result/{average}") { backStackEntry ->
                    val average = backStackEntry.arguments?.getString("average")?.toFloat() ?: 0f
                    ResultScreen(navController, average)
                }
            }
        }
    }
}

// --- PANTALLA 1: LOGIN ---
@Composable
fun LoginScreen(navController: NavHostController) {
    var email by remember { mutableStateOf("") }
    var password by remember { mutableStateOf("") }
    var error by remember { mutableStateOf("") }

    Column(Modifier.fillMaxSize().padding(16.dp), verticalArrangement = Arrangement.Center, horizontalAlignment = Alignment.CenterHorizontally) {
        Text("Iniciar Sesión", fontSize = 24.sp)
        Spacer(Modifier.height(16.dp))
        OutlinedTextField(value = email, onValueChange = { email = it }, label = { Text("Correo") })
        OutlinedTextField(value = password, onValueChange = { password = it }, label = { Text("Contraseña") }, visualTransformation = PasswordVisualTransformation())
        if (error.isNotEmpty()) Text(error, color = Color.Red)
        Button(onClick = {
            if (email.isEmpty() || !email.contains("@")) {
                error = "Correo inválido"
            } else if (password.isEmpty()) {
                error = "Contraseña vacía"
            } else {
                navController.navigate("welcome/$email")
            }
        }) { Text("Ingresar") }
    }
}

// --- PANTALLA 2: BIENVENIDA ---
@Composable
fun WelcomeScreen(navController: NavHostController, email: String) {
    val name = email.split("@")[0]
    Column(Modifier.fillMaxSize(), verticalArrangement = Arrangement.Center, horizontalAlignment = Alignment.CenterHorizontally) {
        Text("Bienvenido, $name", fontSize = 24.sp)
        Button(onClick = { navController.navigate("input") }) { Text("Ir a Notas") }
    }
}

// --- PANTALLA 3: INGRESO DE NOTAS ---
@Composable
fun GradesScreen(navController: NavHostController) {
    var n1 by remember { mutableStateOf("") }
    var n2 by remember { mutableStateOf("") }
    var n3 by remember { mutableStateOf("") }
    var error by remember { mutableStateOf("") }

    Column(
        Modifier.fillMaxSize().padding(16.dp),
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.Center
    ) {
        Text("Ingresar Notas (0.0 - 10.0)", fontSize = 20.sp)
        Spacer(Modifier.height(16.dp))

        // Campos de texto con teclado numérico
        OutlinedTextField(
            value = n1, 
            onValueChange = { n1 = it }, 
            label = { Text("Nota 1") }, 
            keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal),
            modifier = Modifier.fillMaxWidth()
        )
        OutlinedTextField(
            value = n2, 
            onValueChange = { n2 = it }, 
            label = { Text("Nota 2") }, 
            keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal),
            modifier = Modifier.fillMaxWidth()
        )
        OutlinedTextField(
            value = n3, 
            onValueChange = { n3 = it }, 
            label = { Text("Nota 3") }, 
            keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal),
            modifier = Modifier.fillMaxWidth()
        )

        if (error.isNotEmpty()) {
            Text(error, color = Color.Red, modifier = Modifier.padding(8.dp))
        }

        Spacer(Modifier.height(16.dp))

        Button(
            onClick = {
                val v1 = n1.toFloatOrNull()
                val v2 = n2.toFloatOrNull()
                val v3 = n3.toFloatOrNull()

                // VALIDACIÓN: ¿Son números válidos?
                if (v1 == null || v2 == null || v3 == null) {
                    error = "Por favor, completa todos los campos"
                } 
                // VALIDACIÓN: ¿Están entre 0 y 10?
                else if (v1 !in 0.0..10.0 || v2 !in 0.0..10.0 || v3 !in 0.0..10.0) {
                    error = "Las notas deben estar entre 0.0 y 10.0"
                } 
                // Si todo está bien, calculamos
                else {
                    error = ""
                    val avg = (v1 + v2 + v3) / 3
                    navController.navigate("result/$avg")
                }
            },
            modifier = Modifier.fillMaxWidth()
        ) { 
            Text("Calcular Promedio") 
        }
    }
}

// --- PANTALLA 4: RESULTADO ---
@Composable
fun ResultScreen(navController: NavHostController, average: Float) {
    val approved = average >= 6.0
    Column(Modifier.fillMaxSize(), verticalArrangement = Arrangement.Center, horizontalAlignment = Alignment.CenterHorizontally) {
        Text("Promedio: ${"%.2f".format(average)}", fontSize = 30.sp)
        Text(if (approved) "APROBADO" else "REPROBADO", color = if (approved) Color.Green else Color.Red, fontSize = 24.sp)
        Button(onClick = { navController.navigate("input") }) { Text("Volver a intentar") }
        Button(onClick = { navController.navigate("login") }) { Text("Cerrar Sesión") }
    }
}
